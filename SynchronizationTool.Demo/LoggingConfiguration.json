{
  "$schema": "https://json.schemastore.org/appsettings.json",
  "NLog": {
    "autoReload": true,
    "throwConfigExceptions": true,
    "internalLogLevel": "Info",
    "internalLogFile": "${basedir}/../logs/${date:format=yyyy-MM}_${appdomain:format={1\\}}_internal-nlog.log",
    "extensions": [
      {
        "assembly": "NLog.Extensions.Logging"
      },
      {
        "assembly": "NLog.Targets.AtomicFile"
      }
    ],
    "variables": {
      "baseDir": "logs",
      "consoleEnabled": true,
      "fileEnabled": true
    },
    "targets": {
      "blackhole": {
        "type": "Null"
      },
      "logfile": {
        "type": "AtomicFile",
        "fileName": "${var:baseDir}/${shortdate}_logs.log",
        "archiveEvery": "Day",
        "archiveNumbering": "Date",
        "maxArchiveFiles": 3,
        "archiveFileName": "${var:baseDir}/archives/log.${date:format=yyyy-MM-dd}.log",
        "archiveDateFormat": "yyyy-MM-dd",
        "keepFileOpen": false,
        "encoding": "utf-8",
        "layout": "${longdate}|${level:uppercase=true}|${logger}|${message}${exception:format=toString}",
        "archiveAboveSize": 10485760
      },
      "logconsole": { "type": "ColoredConsole" }
    },
    "rules": [
      {
        "logger": "Microsoft.AspNetCore.*",
        "minLevel": "Trace",
        "maxLevel": "Trace",
        "writeTo": "blackhole",
        "final": true
      },
      {
        "logger": "Microsoft.EntityFrameworkCore.*",
        "minLevel": "Info",
        "maxLevel": "Warn",
        "writeTo": "logfile",
        "final": true
      },
      {
        "logger": "Microsoft.AspNetCore.*",
        "minLevel": "Info",
        "maxLevel": "Warn",
        "writeTo": "logfile",
        "final": true
      },
      {
        "logger": "System.Net.Http.HttpClient.Refit.*",
        "minLevel": "Info",
        "maxLevel": "Warn",
        "writeTo": "logfile",
        "final": true
      },
      {
        "logger": "*",
        "minLevel": "Info",
        "maxLevel": "Error",
        "writeTo": "logconsole"
      },
      {
        "logger": "*",
        "minLevel": "Debug",
        "maxLevel": "Error",
        "writeTo": "logfile"
      }
    ]
  }
}
